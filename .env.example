# ===========================================
# {{PROJECT_NAME}} — Variaveis de Ambiente
# ===========================================
# Copie este arquivo para src/backend/.env e preencha com seus valores reais
# NUNCA commite o .env com credenciais reais

# --- Banco de Dados (adapte conforme sua stack) ---
# Exemplo Neo4j:
# NEO4J_URI=neo4j+s://seu-instance.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=sua-senha-aqui
# NEO4J_DATABASE=neo4j

# Exemplo PostgreSQL:
# DATABASE_URL=postgresql://user:pass@localhost:5432/dbname

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
API_SECRET_KEY=gere-uma-chave-secreta-aqui

# --- JWT Auth ---
JWT_SECRET_KEY=gere-outra-chave-secreta-aqui
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ===========================================
# AI/LLM (adapte conforme seu provedor)
# ===========================================

# Exemplo Google Gemini:
# GEMINI_API_KEY=sua-chave-aqui
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODEL_PRO=gemini-2.5-pro
# GEMINI_MODEL_EMBEDDING=gemini-embedding-001

# Exemplo OpenAI:
# OPENAI_API_KEY=sua-chave-aqui
# OPENAI_MODEL=gpt-4o

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
