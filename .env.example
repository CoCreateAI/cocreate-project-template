# ===========================================
# EK.OS — Variaveis de Ambiente
# ===========================================
# Copie este arquivo para src/backend/.env e preencha com seus valores reais
# NUNCA commite o .env com credenciais reais

# --- Neo4j Aura ---
NEO4J_URI=neo4j+s://seu-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=sua-senha-aqui
NEO4J_DATABASE=neo4j

# --- API ---
API_HOST=0.0.0.0
API_PORT=8004
API_ENV=development
API_SECRET_KEY=gere-uma-chave-secreta-aqui

# --- JWT Auth ---
JWT_SECRET_KEY=gere-outra-chave-secreta-aqui
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# --- CORS ---
# Producao: troque para dominio real
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ===========================================
# Google AI — Modelos via AI Studio
# ===========================================
# Uma unica API key serve todos os modelos abaixo
# Obtenha em: https://aistudio.google.com/apikey

GEMINI_API_KEY=sua-chave-google-ai-studio-aqui

# --- Flash Model (rapido, barato) ---
# Uso: analise de documentos, chat, resumos
# Custo: ~$0.15/1M input | ~$0.60/1M output
# Contexto: 1M tokens
GEMINI_MODEL=gemini-2.5-flash

# --- Pro Model (potente, raciocinio complexo) ---
# Uso: ontologia, analise profunda, raciocinio sobre grafo
# Custo: ~$1.25/1M input | ~$10/1M output
# Contexto: 1M tokens
GEMINI_MODEL_PRO=gemini-2.5-pro

# --- Embedding Model ---
# Uso: vector search, similaridade semantica
# Dimensoes: 3072
# Custo: gratuito ate 1500 req/min
GEMINI_MODEL_EMBEDDING=gemini-embedding-001

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8004

# ===========================================
# EK.OS Specific
# ===========================================
# Tamanho maximo de upload por documento (MB)
EKOS_MAX_UPLOAD_SIZE_MB=50
# Dias de retencao de transcricoes processadas
EKOS_TRANSCRIPT_RETENTION_DAYS=90
